    <string name="hornet_info_problem">The Asian Hornet</string>
    <string name="hornet_info_problem_text">Vespa velutina is an invasive predator devastating honey bee colonies. Detecting nests and trapping early in spring is crucial.</string>
    <string name="hornet_info_why_catch">Why Trap?</string>
    <string name="hornet_info_why_catch_text">Trapping queens in spring before nest-building limits colony growth and protects pollinators. Record your catches to track local pressure.</string>
    <string name="hornet_info_report_nest">Found a Nest?</string>
    <string name="hornet_info_report_nest_text">Mark the exact location so local authorities can order professional removal. Anonymous reports are welcome.</string>

