# Backend API URL for the web dashboard (optional — defaults to localhost:8000 for local dev)
NEXT_PUBLIC_API_URL=https://your-backend.example.com/api/v1

# Umami Analytics (optional — omit to disable tracking entirely)
# Get this from your Umami dashboard after adding a website.
# Umami Cloud free tier: https://umami.is  (10k events/month)
# Self-hosted on Vercel: deploy https://github.com/umami-software/umami then use that URL's website ID.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=d7581208-ec85-4dd9-a159-8768d53797a7
